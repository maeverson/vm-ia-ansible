# Gerenciado pelo Ansible (targets na LAN flat 192.168.15.0/24)
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'ollama'
    static_configs:
      - targets: ['192.168.15.50:11434']

  - job_name: 'nvidia-dcgm'
    static_configs:
      - targets: ['192.168.15.50:9400']

  - job_name: 'cadvisor-apps'
    static_configs:
      - targets: ['192.168.15.51:8080']

  - job_name: 'node-exporter'
    static_configs:
      - targets:
          - '192.168.15.50:9100'
          - '192.168.15.51:9100'
